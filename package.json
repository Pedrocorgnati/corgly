{
  "name": "corgly",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "validate": "npm run lint && npm run type-check && npm run test",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:mutation": "stryker run",
    "test:mutation:incremental": "stryker run --incremental",
    "test:mutation:auth": "stryker run --mutate 'src/lib/auth.ts' --mutate 'src/services/auth.service.ts'",
    "test:mutation:payments": "stryker run --mutate 'src/services/stripe.service.ts' --mutate 'src/services/credit.service.ts'",
    "test:mutation:sessions": "stryker run --mutate 'src/services/session.service.ts'",
    "test:e2e": "playwright test",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "docker:dev": "docker compose up",
    "docker:dev:build": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down -v",
    "docker:prod:build": "docker build -t corgly:latest .",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "postinstall": "prisma generate",
    "setup": "./scripts/bootstrap.sh",
    "reset": "./scripts/bootstrap.sh --reset",
    "test:load:smoke": "k6 run --env SCENARIO=smoke tests/load/run-all.js",
    "test:load": "k6 run tests/load/run-all.js",
    "test:load:stress": "k6 run --env SCENARIO=stress tests/load/run-all.js",
    "test:load:availability": "k6 run tests/load/scenarios/03-availability.js",
    "test:load:sessions": "k6 run tests/load/scenarios/06-sessions.js",
    "test:load:checkout": "k6 run tests/load/scenarios/08-checkout.js",
    "test:load:health": "k6 run tests/load/scenarios/09-health-check.js",
    "test:load:feedback": "k6 run tests/load/scenarios/10-feedback.js",
    "test:load:subscriptions": "k6 run tests/load/scenarios/11-subscriptions.js",
    "test:load:profile": "k6 run tests/load/scenarios/12-profile.js",
    "test:load:admin-dashboard": "k6 run tests/load/scenarios/13-admin-dashboard.js"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hocuspocus/provider": "^3.4.4",
    "@hocuspocus/server": "^2.13.5",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@testing-library/dom": "^10.4.1",
    "@tiptap/extension-collaboration": "^3.20.4",
    "@tiptap/extension-collaboration-cursor": "^2.26.2",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.0.2",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.0",
    "resend": "^4.6.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "y-indexeddb": "^9.0.12",
    "yjs": "^13.6.27",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^25.0.1",
    "msw": "^2.12.14",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
